# Local Development Environment
# Copy to .env.local for local development
# Uses PostgreSQL (Docker or local installation)

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=development
ENVIRONMENT=local

# =============================================================================
# DATABASE
# =============================================================================
# Option 1: Docker PostgreSQL (recommended)
# Run: npm run dev:db:up
DATABASE_URL="postgresql://postgres:postgres@localhost:5435/apisandbox_dev"

# Option 2: Local PostgreSQL (Homebrew or direct install)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/apisandbox_dev"

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Sign-in is disabled in local development by default. Set AUTH_ENABLED=true to require login.
# AUTH_ENABLED=false

# Custom JWT + NextAuth legacy secrets (min 32 chars). Generate: openssl rand -base64 32
AUTH_SECRET="local-dev-secret-change-in-production-min-32-characters"
NEXTAUTH_SECRET="local-dev-secret-change-in-production-min-32-characters"
AUTH_JWT_SECRET="local-auth-jwt-secret-at-least-32-characters-long"
# AUTH_JWT_EXPIRES_IN_SECONDS=604800

# Application URL — must match the URL you open in the browser (npm run dev → port 4000)
NEXT_PUBLIC_APP_URL="http://localhost:4000"
AUTH_URL="http://localhost:4000"
NEXTAUTH_URL="http://localhost:4000"

# =============================================================================
# OAUTH PROVIDERS (Optional) – same value for client (button) and server (verify)
# =============================================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# =============================================================================
# FEATURE FLAGS (all off for local dev by default)
# =============================================================================
NEXT_PUBLIC_FF_PREMIUM_PAYWALL=false
NEXT_PUBLIC_FF_STRIPE_CHECKOUT=false
NEXT_PUBLIC_FF_EMAIL_VERIFICATION=false
NEXT_PUBLIC_FF_RATE_LIMITING=false
NEXT_PUBLIC_FF_ANALYTICS=false
# Live demo: "Try demo" on /login and /start — requires DEMO_USER_PASSWORD + npm run db:ensure-demo-user
# NEXT_PUBLIC_FF_DEMO_LOGIN=false
# DEMO_USER_EMAIL=demo@apisandbox.demo
# DEMO_USER_PASSWORD=              # min 12 chars; set in Vercel only, never commit
# NEXT_PUBLIC_DEMO_USER_EMAIL=  # optional legacy; banner uses DEMO_USER_EMAIL from the server

# =============================================================================
# STRIPE (optional for local — only needed with FF_STRIPE_CHECKOUT=true)
# =============================================================================
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""

# =============================================================================
# UPSTASH REDIS (optional — only needed with FF_RATE_LIMITING=true)
# =============================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =============================================================================
# RESEND (optional — only needed with FF_EMAIL_VERIFICATION=true)
# =============================================================================
RESEND_API_KEY=""
EMAIL_FROM="API Sandbox <noreply@localhost>"

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=debug

# =============================================================================
# SERVER
# =============================================================================
PORT=4000
