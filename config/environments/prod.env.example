# Production Environment (Vercel)
# Set in Vercel Dashboard → Settings → Environment Variables → Production
# NEVER commit real values to Git
#
# Preview deployments use config/environments/preview.env.example (Test Stripe, separate flags).

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=production
ENVIRONMENT=prod

# =============================================================================
# DATABASE (Vercel Postgres — Storage → Create Database)
# =============================================================================
# Vercel auto-creates these when you add Postgres. Reference them; do not paste URLs.
DATABASE_URL="$POSTGRES_PRISMA_URL"
# Prisma on Neon pooler: lib/prisma.ts adds ?pgbouncer=true&connection_limit=1 automatically.
# Optional for Prisma migrations/direct connections (if using directUrl in schema):
# DATABASE_URL_UNPOOLED="$POSTGRES_URL"

# External Postgres example:
# DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# =============================================================================
# AUTHENTICATION (REQUIRED)
# =============================================================================
# Generate once per environment: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"
NEXTAUTH_SECRET="CHANGE_ME_SAME_VALUE_AS_AUTH_SECRET"

# JWT for register/login/Google (/api/auth/*). Required on Preview for all branches.
# If unset, token-service falls back to AUTH_SECRET — but Preview PRs often need this explicit.
AUTH_JWT_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"

NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
AUTH_URL="https://your-app.vercel.app"
NEXTAUTH_URL="https://your-app.vercel.app"

# =============================================================================
# GOOGLE SIGN-IN (recommended for production)
# =============================================================================
# 1. Google Cloud Console → OAuth client (Web application)
# 2. Authorized JavaScript origins: https://your-app.vercel.app (+ preview URLs)
# 3. Set GOOGLE_CLIENT_ID on Vercel (server runtime — enables button + token verify)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
# Optional duplicate for build-time inlining; server pages also read GOOGLE_CLIENT_ID at runtime.
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# =============================================================================
# DEPLOY CHECKLIST
# =============================================================================
# 1. Vercel → Storage → Postgres → link to project
# 2. DATABASE_URL=$POSTGRES_PRISMA_URL (Production scope only)
# 3. AUTH_SECRET + NEXTAUTH_SECRET (32+ chars, same value)
# 4. GOOGLE_CLIENT_ID (+ add production URL to Google authorized origins)
# 5. NEXT_PUBLIC_APP_URL matches live production URL
# 6. AUTH_JWT_SECRET on Production (Preview uses preview.env.example)
# 7. After first deploy: npx prisma db push or migrate deploy against prod DB
# 8. Smoke: docs/DEPLOYMENT.md (health + optional test:prod)
# 9. SaaS: docs/SAAS.md — feature flags + Stripe + Upstash

# =============================================================================
# SAAS FEATURE FLAGS (production)
# =============================================================================
NEXT_PUBLIC_FF_PREMIUM_PAYWALL=true
NEXT_PUBLIC_FF_STRIPE_CHECKOUT=true
NEXT_PUBLIC_FF_BILLING_PORTAL=true
NEXT_PUBLIC_FF_RATE_LIMITING=true
NEXT_PUBLIC_FF_DEMO_LOGIN=false
NEXT_PUBLIC_FF_ANALYTICS=true

# =============================================================================
# STRIPE BILLING
# =============================================================================
# Production readiness rejects test keys. Use a Live-mode product, price, and webhook.
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."

# =============================================================================
# RATE LIMITING (Upstash — required when FF_RATE_LIMITING=true)
# =============================================================================
UPSTASH_REDIS_REST_URL="https://....upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# Never enable in public production unless intentional:
# ALLOW_DEMO_LOGIN_IN_PRODUCTION=false
