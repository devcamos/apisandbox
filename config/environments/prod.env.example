# Production Environment (Vercel)
# Set these in Vercel Dashboard → Settings → Environment Variables
# NEVER commit real values to Git

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=production
ENVIRONMENT=prod

# =============================================================================
# DATABASE
# =============================================================================
# Vercel Postgres automatically provides these:
# Use POSTGRES_PRISMA_URL for Prisma (includes connection pooling)
DATABASE_URL="${POSTGRES_PRISMA_URL}"

# Alternative: External PostgreSQL connection string
# DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# =============================================================================
# AUTHENTICATION
# =============================================================================
# NextAuth.js v5 Secret (REQUIRED)
# Generate with: openssl rand -base64 32
# Must be at least 32 characters
AUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"

# Application URL (automatically set by Vercel)
# NEXT_PUBLIC_APP_URL is auto-set to https://your-app.vercel.app
# Or set manually: NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# =============================================================================
# OAUTH PROVIDERS (Optional)
# =============================================================================
# Google OAuth - Configure in Google Cloud Console
# Callback URL: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# =============================================================================
# NOTES
# =============================================================================
# 1. Create Vercel Postgres database in Vercel Dashboard → Storage
# 2. Vercel automatically sets POSTGRES_PRISMA_URL
# 3. Set DATABASE_URL=${POSTGRES_PRISMA_URL} in environment variables
# 4. Generate strong AUTH_SECRET for production
# 5. Run migrations after first deployment: npx prisma migrate deploy
