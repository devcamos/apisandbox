# Production Environment (Vercel)
# Set these in Vercel Dashboard → Settings → Environment Variables
# NEVER commit real values to Git

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=production
ENVIRONMENT=prod

# =============================================================================
# DATABASE (Vercel Postgres — Storage → Create Database)
# =============================================================================
# Vercel auto-creates these when you add Postgres. Reference them; do not paste URLs.
DATABASE_URL="$POSTGRES_PRISMA_URL"
# Optional for Prisma migrations/direct connections (if using directUrl in schema):
# DATABASE_URL_UNPOOLED="$POSTGRES_URL"

# External Postgres example:
# DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# =============================================================================
# AUTHENTICATION (REQUIRED)
# =============================================================================
# Generate once per environment: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"
NEXTAUTH_SECRET="CHANGE_ME_SAME_VALUE_AS_AUTH_SECRET"

# Optional dedicated JWT signing secret. If unset, token-service uses AUTH_SECRET.
# Production: omit this and use AUTH_SECRET only, OR set to the same generated value.
# AUTH_JWT_SECRET="CHANGE_ME_SAME_VALUE_AS_AUTH_SECRET"

NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
AUTH_URL="https://your-app.vercel.app"
NEXTAUTH_URL="https://your-app.vercel.app"

# =============================================================================
# GOOGLE SIGN-IN (recommended for production)
# =============================================================================
# 1. Google Cloud Console → OAuth client (Web application)
# 2. Authorized JavaScript origins: https://your-app.vercel.app (+ preview URLs)
# 3. Set GOOGLE_CLIENT_ID on Vercel (server runtime — enables button + token verify)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
# Optional duplicate for build-time inlining; server pages also read GOOGLE_CLIENT_ID at runtime.
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# =============================================================================
# DEPLOY CHECKLIST
# =============================================================================
# 1. Vercel → Storage → Postgres → link to project
# 2. DATABASE_URL=$POSTGRES_PRISMA_URL (Production + Preview)
# 3. AUTH_SECRET + NEXTAUTH_SECRET (32+ chars, same value)
# 4. GOOGLE_CLIENT_ID (+ add Vercel URL to Google authorized origins)
# 5. NEXT_PUBLIC_APP_URL matches live URL
# 6. After first deploy: npx prisma db push or migrate deploy against prod DB
