# Vercel Preview Environment
# Set in Vercel Dashboard → Settings → Environment Variables → Preview → all branches
# NEVER commit real values to Git
#
# Template for PR preview deployments. Use Stripe **Test mode** keys here.
# Production values live in config/environments/prod.env.example

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=production
ENVIRONMENT=preview
# VERCEL_ENV=preview is set automatically on Vercel Preview deployments

# =============================================================================
# DATABASE (Vercel Postgres / Neon preview branch)
# =============================================================================
DATABASE_URL="$POSTGRES_PRISMA_URL"

# =============================================================================
# AUTHENTICATION (REQUIRED on Preview — scope to all branches)
# =============================================================================
# Generate: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"
NEXTAUTH_SECRET="CHANGE_ME_SAME_VALUE_AS_AUTH_SECRET"
AUTH_JWT_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"

# Use the deployment URL for this preview (or a stable preview alias).
# Vercel also sets VERCEL_URL; the app falls back when NEXT_PUBLIC_APP_URL is unset.
NEXT_PUBLIC_APP_URL="https://your-preview-host.vercel.app"
AUTH_URL="https://your-preview-host.vercel.app"
NEXTAUTH_URL="https://your-preview-host.vercel.app"

# =============================================================================
# GOOGLE SIGN-IN
# =============================================================================
# Add each preview origin to Google Cloud → OAuth → Authorized JavaScript origins.
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# =============================================================================
# PREVIEW CHECKLIST
# =============================================================================
# 1. DATABASE_URL=$POSTGRES_PRISMA_URL (Preview scope, all branches)
# 2. AUTH_SECRET + AUTH_JWT_SECRET (32+ chars; Preview → all branches)
# 3. GOOGLE_CLIENT_ID + add preview host to Google authorized origins
# 4. NEXT_PUBLIC_APP_URL matches the preview host under test
# 5. After first deploy: npx prisma migrate deploy against the preview DB
# 6. Smoke: curl https://<preview-host>/api/health/auth | jq .data.jwtSecretConfigured
# 7. Test users: docs/TEST_USERS.md (Preview section — do not assume local seeds exist)

# =============================================================================
# SAAS FEATURE FLAGS (preview — Stripe Test mode)
# =============================================================================
# See docs/FEATURE_FLAGS.md. Enable Stripe only when Test keys + webhooks are configured.
NEXT_PUBLIC_FF_PREMIUM_PAYWALL=true
NEXT_PUBLIC_FF_STRIPE_CHECKOUT=false
NEXT_PUBLIC_FF_BILLING_PORTAL=false
NEXT_PUBLIC_FF_RATE_LIMITING=false
NEXT_PUBLIC_FF_DEMO_LOGIN=false
NEXT_PUBLIC_FF_ANALYTICS=false

# =============================================================================
# STRIPE BILLING (Test mode only on Preview)
# =============================================================================
# Use sk_test_... / price_... from Stripe Dashboard (Test mode).
# Webhook: https://<preview-host>/api/webhooks/stripe or Stripe CLI for local parity.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."

# =============================================================================
# ASSISTANT (optional — Preview scope, server-only)
# =============================================================================
OPENAI_API_KEY=""
# GEMINI_API_KEY=""

# =============================================================================
# RATE LIMITING (optional)
# =============================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional shared demo account (see docs/TEST_USERS.md):
# DEMO_USER_EMAIL=demo@apisandbox.demo
# DEMO_USER_PASSWORD=
