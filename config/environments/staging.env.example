# Staging Environment (Docker / dev branch)
# Used when running via docker-compose.staging.yml or deploying to staging

NODE_ENV=staging
ENVIRONMENT=staging

# Database (postgres-staging container when using docker-compose.staging)
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/apisandbox_staging"

# Auth
AUTH_SECRET="staging-secret-change-in-production-min-32-characters"
NEXTAUTH_SECRET="staging-secret-change-in-production-min-32-characters"
NEXT_PUBLIC_APP_URL="http://localhost:4000"

# Feature: when false/unset, premium content is unlocked so all nav works without sign-in. When true (live), premium requires sign-up.
# NEXT_PUBLIC_SIGNUP_REQUIRED=false

# Google OAuth (staging) – set in .env; client ID must be exposed to browser for Sign-in button. See docs/DEPLOYMENT.md
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

PORT=4000
