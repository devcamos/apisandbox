// This is your Prisma schema file for NextAuth.js v5
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  // MENTOR NOTE: Mono-Environment Framework
  // PostgreSQL for all environments (local, dev, staging, prod)
  // Works with: Local PostgreSQL, Docker, Vercel Postgres, AWS RDS, etc.
  // Only the DATABASE_URL changes - same code everywhere!
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js v5 required models
// These models are required by @auth/prisma-adapter
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// MENTOR NOTE: Subscription Tiers
// FREE: Access to Phase 1 only
// PREMIUM: Access to all phases (1-4) + Cloud section
enum SubscriptionTier {
  FREE
  PREMIUM
}

model User {
  id                       String           @id @default(cuid())
  name                     String?
  email                    String           @unique
  emailVerified            DateTime?
  image                    String?
  // Custom fields for email/password auth
  passwordHash             String? // bcrypt hash - NEVER store plain text!
  // Security fields
  loginAttempts            Int              @default(0)
  lockedUntil              DateTime?
  isActive                 Boolean          @default(true)
  // Stripe billing
  stripeCustomerId         String?          @unique
  stripeSubscriptionId     String?
  stripeSubscriptionStatus String?
  stripeCurrentPeriodEnd   DateTime?
  // Subscription fields
  subscriptionTier         SubscriptionTier @default(FREE)
  subscriptionExpiresAt    DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  accounts            Account[]
  sessions            Session[]
  verificationToken   VerificationToken[]
  profile             UserProfile?
  phaseProgress       UserPhaseProgress[]
  appGuide            UserAppGuide?
  apiTokens           ApiToken[]
  apiTokenAuditEvents ApiTokenAuditEvent[]
}

model StripeWebhookEvent {
  id          String    @id
  type        String
  status      String    @default("processing")
  attempts    Int       @default(1)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  name        String
  tokenHash   String    @unique
  tokenPrefix String
  scopes      String[]
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditEvents ApiTokenAuditEvent[]

  @@index([userId])
  @@index([tokenPrefix])
}

model ApiTokenAuditEvent {
  id        String   @id @default(cuid())
  userId    String
  tokenId   String?
  event     String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token ApiToken? @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tokenId])
}

model UserAppGuide {
  id          String    @id @default(cuid())
  userId      String    @unique
  steps       Json      @default("{}")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPhaseProgress {
  id             String    @id @default(cuid())
  userId         String
  phaseNumber    Int
  xpEarned       Int       @default(0)
  totalQuestions Int       @default(0)
  correctAnswers Int       @default(0)
  attempts       Int       @default(0)
  completedAt    DateTime?
  lastAttemptAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phaseNumber])
  @@index([userId])
}

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  firstName         String?
  lastName          String?
  avatarUrl         String?
  roleLabel         String?
  identityStatement String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  user User @relation(fields: [identifier], references: [email], onDelete: Cascade)

  @@unique([identifier, token])
}
