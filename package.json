{
  "name": "api-integration-training",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000 --webpack",
    "local-lite": "bash ./scripts/local-lite.sh",
    "dev:local-lite": "bash ./scripts/local-lite.sh",
    "build": "rm -rf node_modules/.prisma && env -u PRISMA_GENERATE_DATAPROXY prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:unit:ci": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:visual": "playwright test tests/visual-regression.spec.ts",
    "test:coverage": "playwright test --reporter=html",
    "test:ci": "playwright test --reporter=github",
    "test:ci:chromium": "playwright test --project=chromium --reporter=github",
    "test:ci:smoke": "playwright test tests/ci-smoke.spec.ts --project=chromium --reporter=github",
    "verify:ci": "bash scripts/verify-ci-local.sh",
    "verify:ci:strict": "npm ci && bash scripts/verify-ci-local.sh",
    "verify:pr": "npm run verify:ci:strict",
    "test:all": "playwright test --reporter=list",
    "test:staging": "STAGING_TEST=1 playwright test tests/staging.spec.ts --project=staging",
    "test:prod": "playwright test tests/prod-deployment-auth.spec.ts --project=chromium",
    "coverage:check": "node scripts/check-coverage.js",
    "validate:compose": "bash scripts/validate-compose.sh",
    "pr:close-stale-codex": "bash ./scripts/gh-close-codex-prs.sh",
    "sonar:local": "bash scripts/sonar-local.sh",
    "sonar:local:full": "npm run test:unit -- --coverage && bash scripts/sonar-local.sh",
    "sonar:status": "bash scripts/sonar-status.sh",
    "postinstall": "env -u PRISMA_GENERATE_DATAPROXY prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:ensure-test-users": "node scripts/ensure-test-users.js",
    "db:ensure-demo-user": "node scripts/ensure-demo-user.js",
    "db:studio": "prisma studio",
    "dev:db:up": "docker compose --profile dev up -d postgres-dev",
    "dev:db:down": "docker compose --profile dev down",
    "dev:db:logs": "docker compose --profile dev logs -f postgres-dev",
    "staging:lite": "bash ./scripts/staging-lite.sh",
    "staging:up": "docker compose -f docker-compose.yml -f docker-compose.staging.yml up -d",
    "staging:down": "docker compose -f docker-compose.yml -f docker-compose.staging.yml down",
    "staging:logs": "docker compose -f docker-compose.yml -f docker-compose.staging.yml logs -f",
    "staging:db:studio": "DATABASE_URL='postgresql://postgres:postgres@localhost:5434/apisandbox_staging' prisma studio",
    "env:local": "cp config/environments/local.env.example .env.local",
    "env:staging": "cp config/environments/staging.env.example .env.staging.local",
    "env:prod": "echo 'See config/environments/prod.env.example for Vercel environment variables'"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@google/genai": "^2.0.1",
    "@gsap/react": "^2.1.2",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.38.0",
    "google-auth-library": "^10.5.0",
    "gsap": "^3.15.0",
    "isomorphic-dompurify": "^3.12.0",
    "lucide-react": "^0.562.0",
    "mermaid": "^10.9.1",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.37.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "resend": "^6.12.2",
    "stripe": "^22.3.0",
    "three": "^0.183.2",
    "ws": "^8.21.0",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/mermaid": "^9.1.0",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.5"
  }
}
