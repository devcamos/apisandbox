{
  "name": "api-integration-training",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:visual": "playwright test tests/visual-regression.spec.ts",
    "test:coverage": "playwright test --reporter=html",
    "test:ci": "playwright test --reporter=github",
    "test:all": "playwright test --reporter=list",
    "coverage:check": "node scripts/check-coverage.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:up": "docker-compose up -d postgres-dev",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f postgres-dev",
    "env:local": "cp config/environments/local.env.example .env.local",
    "env:prod": "echo 'See config/environments/prod.env.example for Vercel environment variables'"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.1",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.562.0",
    "mermaid": "^10.9.1",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/mermaid": "^9.1.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.1",
    "postcss": "^8",
    "prisma": "^6.19.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  }
}
