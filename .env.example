# Root env template for Prisma CLI and tooling.
# Copy to .env (Prisma) and config/environments/local.env.example → .env.local (Next.js runtime).
#
# Quick start:
#   cp .env.example .env
#   cp config/environments/local.env.example .env.local
#   npm run dev:db:up
#   npx prisma db push
#   npm run dev

# =============================================================================
# DATABASE (required)
# =============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5435/apisandbox_dev"

# =============================================================================
# AUTH — custom JWT + NextAuth legacy (required, min 32 chars each)
# Generate: openssl rand -base64 32
# =============================================================================
AUTH_SECRET="local-dev-secret-change-in-production-min-32-characters"
NEXTAUTH_SECRET="local-dev-secret-change-in-production-min-32-characters"
AUTH_JWT_SECRET="local-auth-jwt-secret-at-least-32-characters-long"
# AUTH_JWT_EXPIRES_IN_SECONDS=604800

# Must match the URL you open in the browser (port 4000 for npm run dev)
AUTH_URL="http://localhost:4000"
NEXTAUTH_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:4000"

# =============================================================================
# GOOGLE SIGN-IN (optional — email/password works without these)
# Same client ID for server verify + public GSI button
# =============================================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# =============================================================================
# DEMO LOGIN (optional)
# =============================================================================
# NEXT_PUBLIC_FF_DEMO_LOGIN=false
# DEMO_USER_EMAIL=demo@apisandbox.demo
# DEMO_USER_PASSWORD=
